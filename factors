#!/usr/bin/env python3
import sys


def factorize(n):
    for i in range(2, int(n**0.5) + 1):
        if n % i == 0:
            return i, n // i
    return n, 1


if __name__ == '__main__':
    if len(sys.argv) != 2:
        sys.exit()

    with open(sys.argv[1], 'r') as f:
        numbers = [int(line.strip()) for line in f if line.strip()]

    for n in numbers:
        factors = factorize(n)
        print('{}={}*{}'.format(n, factors[1], factors[0]))
