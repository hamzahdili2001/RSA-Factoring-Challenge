#!/usr/bin/python3
import sys

def factorize(number):
    i = 2

    if number < 2:
        return None

    while (number % i):
        i += 1    
    return f"{number:.0f}={number / i:.0f}*{i:.0f}"


def process_file(filename):
    with open(filename) as file:
        lines = file.readlines()
        fac = map(lambda l: factorize(int(l.strip())), lines)
        vfac = filter(lambda f: f is not None, fac)
        for f in vfac:
            print(f)

if __name__ == '__main__':
    if len(sys.argv) != 2:
        print("Usage: factors <file>")
        sys.exit(1)
    process_file(sys.argv[1])

