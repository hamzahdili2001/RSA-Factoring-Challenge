#!/usr/bin/env python3
import sys
import math


def factorize(n):
    if n % 2 == 0:
        return 2, n // 2

    for i in range(3, int(math.sqrt(n)) + 1, 2):
        if n % i == 0:
            return i, n // i

    return n, 1


if __name__ == '__main__':
    if len(sys.argv) != 2:
        sys.exit()

    with open(sys.argv[1], 'r') as f:
        numbers = [int(line.strip()) for line in f if line.strip()]

    for n in numbers:
        factors = factorize(n)
        print(f'{n}={factors[1]}*{factors[0]}')
