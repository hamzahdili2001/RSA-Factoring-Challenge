#!/usr/bin/python3
import sys


def factorize(n):
    for i in range(2, int(n**0.5) + 1):
        if n % i == 0:
            return i, n // i
    return None


if __name__ == '__main__':
    if len(sys.argv) != 2:
        sys.exit(1)

    with open(sys.argv[1], 'r') as f:
        numbers = [int(line.strip()) for line in f.readlines()]
    for n in numbers:
        factors = factorize(n)
        if factors is not None:
            print('{}={}*{}'.format(n, factors[1], factors[0]))
